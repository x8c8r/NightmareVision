<?xml version="1.0" encoding="utf-8" ?>
<dialog id="_SongTab" title="Song" width="360" modal="false" style="padding: 5px;">
	<tabview id="tv1" width="100%" styleName="full-width-buttons">
		<vbox text="Metadata" width="100%" style="padding: 5px;">
			<grid width="100%" columns="2">
				<label text="Song Title:" width="80" verticalAlign="center"/>
				<textfield width="100%" id="songNameField" horizontalAlign="right" text="Bopeebo"/>
			</grid>
			
			<spacer height="5"/>
			<rule/>
			<spacer height="5"/>
			
			<hbox width="100%" style="spacing: 10px;">
				<vbox width="30%">
					<label text="Initial BPM:" horizontalAlign="center"/>
					<number-stepper pos="120" step="1" width="100%" id="initialBpmStepper" min="1" max="120"/>
				</vbox>
				<vbox width="30%">
					<label text="Scroll Speed:" horizontalAlign="center"/>
					<number-stepper pos="2" step="0.1" width="100%" id="songSpeedStepper" min="0.1" max="10" precision="2"/>
				</vbox>

				<rule direction="vertical" height="100%"/>
				
				<vbox width="20%">
					<label text="Strums:" horizontalAlign="center"/>
					<number-stepper pos="1" step="1" width="100%" id="strumsStepper" min="1" max="8" precision="0"/>
				</vbox>
				<vbox width="20%">
					<label text="Keys:" horizontalAlign="center"/>
					<number-stepper pos="4" step="1" width="100%" id="keysStepper" min="1" max="9" precision="0"/>
				</vbox>
			</hbox>
			
			<spacer height="5"/>
			<rule/>
			<spacer height="5"/>
			
			<hbox width="100%" style="spacing: 10px;">
				<vbox width="100%">
					<label text="Player 1:" horizontalAlign="center"/>
					<dropdown width="100%" searchable="true" searchPrompt="bf" id="bfDropdown">
						<data> <item text="bf"/> </data>
					</dropdown>
				</vbox>
				<vbox width="100%">
					<label text="Player 2:" horizontalAlign="center"/>
					<dropdown width="100%" searchable="true" searchPrompt="dad" id="dadDropdown">
						<data> <item text="dad"/> </data>
					</dropdown>
				</vbox>
				<vbox width="100%">
					<label text="Girlfriend:" horizontalAlign="center"/>
					<dropdown width="100%" searchable="true" searchPrompt="gf" id="gfDropdown">
						<data> <item text="gf"/> </data>
					</dropdown>
				</vbox>
			</hbox>

			<spacer height="5"/>
			<rule/>
			<spacer height="5"/>
			
			<hbox width="100%" style="spacing: 10px;">
				<vbox width="100%">
					<label text="Stage:" horizontalAlign="center"/>
					<dropdown width="100%" searchable="true" searchPrompt="stage" id="stageDropdown">
						<data> <item text="stage"/> </data>
					</dropdown>
				</vbox>
				<vbox width="100%">
					<label text="Note Skin:" horizontalAlign="center"/>
					<dropdown width="100%" searchable="true" searchPrompt="default" id="noteSkinDropdown">
						<data> <item text="default"/> </data>
					</dropdown>
				</vbox>
				<!--vbox width="100%">
					<label text="Splash Skin:" horizontalAlign="center"/>
					<dropdown width="100%" searchable="true" searchPrompt="default" id="splashSkinDropdown">
						<data> <item text="default"/> </data>
					</dropdown>
				</vbox-->
			</hbox>
		</vbox>
		<vbox text="Section" width="100%" style="padding: 5px;">
			<checkbox text="Camera focused on opponent?" id="mustHitCheckbox" verticalAlign="center" tooltip="If enabled, the camera will be focused on the opponent instead of the player."/>
			<checkbox text="Girlfriend sings?" id="gfSectionCheckbox" verticalAlign="center" tooltip="If enabled, Girlfriend will sing instead of the currently focused character."/>
			
			<spacer height="5"/>
			<rule/>
			<spacer height="5"/>

			<hbox width="100%">
				<label text="Beats per section:" width="100%" verticalAlign="center"/>
				<number-stepper pos="4" step="1" width="100" id="sectionBeatsStepper" horizontalAlign="right" min="1" max="16" precision="0" tooltip="How many beats should this section last?"/>
			</hbox>
			
			<hbox width="100%">
				<checkbox text="Change BPM?" width="100%" id="bpmCheckbox" verticalAlign="center" tooltip="If enabled, the song's BPM will change on this section."/>
				<number-stepper pos="120" step="1" width="100" id="bpmStepper" horizontalAlign="right" min="1" max="999" tooltip="The new BPM for this section." disabled="${!bpmCheckbox.selected}"/>
			</hbox>
			
			<spacer height="5"/>
			<rule/>
			<spacer height="5"/>

			<grid width="100%" columns="3" style="spacing: 10px;">
				<button text="Copy Section" id="copySectionButton" width="125"/>
				<spacer width="100%"/>
				<button text="Paste Section" id="pasteSectionButton" width="125"/>
				
				<button text="Clone Last" id="copyLastSectionButton" width="125"/>
				<spacer width="100%"/>
				<number-stepper pos="1" step="1" id="copyLastSectionStepper" horizontalAlign="right" precision="0" width="125" tooltip="Behind how many sections to clone."/>
			</grid>
			
			<spacer height="5"/>
			<hbox width="100%">
				<label text="Copy / Paste inclusions:" verticalAlign="center" width="100%"/>

				<vbox width="125" style="spacing: 10px;">
					<checkbox text="Notes" selected="true" id="copyNotesCheckbox" tooltip="If unchecked, the section's notes will be excluded when copying."/>
					<checkbox text="Events" selected="true" id="copyEventsCheckbox" tooltip="If unchecked, the section's events will be excluded when copying."/>
				</vbox>
			</hbox>
			
			<spacer height="5"/>
			<rule/>
			<spacer height="5"/>

			<button text="Clear Section" id="clearButton" horizontalAlign="center" style="background-color: #a01926;"/>
		</vbox>
		<vbox text="Notes" width="100%" style="padding: 5px;">
			<grid width="100%" columns="2">
				<label text="Note Type:" width="80" verticalAlign="center"/>
				<dropdown searchable="true" width="100%" searchPrompt="" id="noteTypeDropdown">
					<data>
						<item text="Default"/>
						<item text="GF Sing"/>
						<item text="Alt Animation"/>
					</data>
				</dropdown>

				<label text="Time:" width="80" verticalAlign="center"/>
				<number-stepper width="100%" pos="0" step="1" id="strumTimeStepper" horizontalAlign="right" min="0"/>
				
				<label text="Length:" width="80" verticalAlign="center"/>
				<number-stepper width="100%" pos="0" step="1" id="sustainLengthStepper" horizontalAlign="right" min="0"/>
			</grid>
			
			<spacer height="1"/>
			<rule/>
			<spacer height="1"/>
			
			<hbox width="100%" style="spacing: 10px;">
				<button text="Mirror Horizontal" id="mirrorHorizontalButton" width="125"/>
				<spacer width="100%"/>
				<button text="Mirror Vertical" id="mirrorVerticalButton" width="125"/>
			</hbox>

			<spacer/>

			<hbox width="100%" style="spacing: 10px;">
				<button text="Choir" id="choirNotesButton" width="100%" tooltip="Copies selected notes to all strumlines."/>
				<button text="Shift" id="shiftNotesButton" width="100%" tooltip="Shifts all selected notes to the next strumline."/>
				<button text="Swap" id="swapNotesButton" width="100%" tooltip="Swaps all selected notes to the strumline on the opposite side."/>
			</hbox>
			
			<spacer height="5"/>
			<rule/>
			<spacer height="5"/>

			<button text="Clear all Notes" id="clearNotesButton" horizontalAlign="center" style="background-color: #a01926;"/>
		</vbox>
		<vbox text="Events" width="100%" style="padding: 5px;">
			<grid width="100%" columns="2">
				<label text="Event:" width="80" verticalAlign="center"/>
				<dropdown searchable="true" width="100%" searchPrompt="" id="eventDropdown">
					<data>
						<item text="Empty"/>
						<item text="Hey!"/>
					</data>
				</dropdown>
			</grid>

			<spacer height="3"/>
			
			<hbox width="100%">
				<button text="-" width="36" style="background-color: #a01926;"/>
				<button text="+" width="36" style="background-color: #156015;"/>
				
				<spacer width="20"/>

				<button text="&lt;" width="36"/>
				<button text="&gt;" width="36"/>
				
				<spacer width="100%"/>

				<label text="Selected 1 / 1" id="eventSelected" horizontalAlign="right" verticalAlign="center"/>
			</hbox>

			<spacer height="5"/>
			<rule/>
			<spacer height="5"/>

			<vbox width="100%">
				<label text="Event Name" id="eventName" horizontalAlign="center"/>

				<box id="eventForm" width="100%" style="padding: 5px;">
					<grid width="100%" columns="2">
						<label text="Value 1:" width="80" verticalAlign="center"/>
						<textfield width="100%" id="value1Field" horizontalAlign="right" text=""/>
						
						<label text="Value 2:" width="80" verticalAlign="center"/>
						<textfield width="100%" id="value2Field" horizontalAlign="right" text=""/>
					</grid>
				</box>
			</vbox>

			<spacer height="5"/>
			<rule/>
			<spacer height="5"/>

			<label id="eventDescription" text="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua." width="100%"/>
			
			<spacer height="5"/>
			<rule/>
			<spacer height="5"/>

			<button text="Clear all Events" id="clearEventsButton" horizontalAlign="center" style="background-color: #a01926;"/>
		</vbox>
	</tabview>
</dialog>